flowchart TD
    %% Event Sources
    E1[("New Email Event")] -->|"Triggers"| P1
    E2[("Email Read Event")] -->|"Triggers"| P2
    E3[("User Search Event")] -->|"Triggers"| P3
    E4[("Thread Update Event")] -->|"Triggers"| P4
    
    %% Event Bus
    subgraph "Event Message Bus"
        EB["Redis/Kafka Event Bus
        - Event Distribution
        - Message Queuing
        - Event Routing"]
    end
    
    %% Processors
    subgraph "Event Processors"
        P1["Email Ingestion Processor
        - Message Parsing
        - Initial Classification"]
        
        P2["Content Analysis Processor
        - Deep Content Processing
        - Sentiment & Intent Analysis"]
        
        P3["Search Processing
        - Query Analysis
        - Vector & Metadata Search"]
        
        P4["Thread Processing
        - Conversation Tracking
        - Context Building"]
    end
    
    %% Data Stores
    subgraph "Data Layer"
        D1[("Email Raw Store")]
        D2[("Vector Embeddings")]
        D3[("Metadata Store")]
        D4[("Knowledge Graph")]
    end
    
    %% Services
    subgraph "Service Layer"
        S1["AI Analysis Service
        - LLM Processing
        - Classification"]
        
        S2["Persona Matching Service
        - Style Templates
        - Response Formatting"]
        
        S3["Export Service
        - Markdown Generation
        - Obsidian Integration"]
    end
    
    %% Outputs
    subgraph "Output Layer"
        O1["Email UI Updates"]
        O2["Notification Events"]
        O3["Obsidian Documents"]
        O4["Visualization Data"]
    end
    
    %% Connecting the flow
    P1 & P2 & P3 & P4 -->|"Publish Events"| EB
    EB -->|"Subscribe"| S1 & S2 & S3
    
    P1 -->|"Store Raw Data"| D1
    P2 -->|"Store Embeddings"| D2
    P3 -->|"Query"| D2 & D3 & D4
    P4 -->|"Update"| D3 & D4
    
    S1 -->|"Read"| D1
    S1 -->|"Write"| D2 & D3
    S2 -->|"Read"| D2 & D3 & D4
    S3 -->|"Read"| D1 & D3 & D4
    
    S1 -->|"Generate"| O1 & O2
    S2 -->|"Generate"| O1
    S3 -->|"Generate"| O3 & O4
    
    %% Event Flow Cycle
    O1 & O2 -->|"Can Generate"| E2 & E4
